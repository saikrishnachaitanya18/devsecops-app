<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Command Injection — VulnApp</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container">
    <div class="page-header">
      <h1>⚡ Command Injection</h1>
      <p>Vulnerabilities: OS Command Injection (exec, execSync), eval(), vm sandbox escape</p>
    </div>

    <!-- Ping Command Injection -->
    <div class="form-card">
      <h2>1. Ping Tool (exec — Command Injection)</h2>
      <form method="POST" action="/cmdi/ping">
        <div class="form-group">
          <label for="host">Host to Ping</label>
          <input type="text" id="host" name="host" placeholder="127.0.0.1; whoami">
        </div>
        <button type="submit" class="btn btn-primary">Ping</button>
      </form>

      <div class="hint-box">
        <h4>💡 Payloads</h4>
        <code>127.0.0.1; whoami</code><br>
        <code>127.0.0.1 && cat /etc/passwd</code><br>
        <code>127.0.0.1 | dir</code>
      </div>
    </div>

    <!-- DNS Lookup Command Injection -->
    <div class="form-card">
      <h2>2. DNS Lookup (execSync — Command Injection)</h2>
      <form method="POST" action="/cmdi/dns">
        <div class="form-group">
          <label for="domain">Domain to Lookup</label>
          <input type="text" id="domain" name="domain" placeholder="google.com; dir">
        </div>
        <button type="submit" class="btn btn-primary">Lookup</button>
      </form>
    </div>

    <!-- Eval Code Injection -->
    <div class="form-card">
      <h2>3. Code Evaluator (eval — Code Injection)</h2>
      <form method="POST" action="/cmdi/eval">
        <div class="form-group">
          <label for="code">JavaScript Code</label>
          <textarea id="code" name="code" rows="4" placeholder="require('child_process').execSync('whoami').toString()"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Execute</button>
      </form>

      <div class="hint-box">
        <h4>💡 Payloads</h4>
        <code>2 + 2</code><br>
        <code>require('fs').readFileSync('/etc/passwd', 'utf-8')</code><br>
        <code>require('child_process').execSync('whoami').toString()</code><br>
        <code>process.env</code>
      </div>
    </div>

    <% if (output) { %>
      <div class="form-card">
        <h2>Output:</h2>
        <pre class="output-box"><%= output %></pre>
      </div>
    <% } %>

    <% if (error) { %>
      <div class="form-card">
        <div class="alert alert-error"><%= error %></div>
      </div>
    <% } %>

    <% if (evalOutput) { %>
      <div class="form-card">
        <h2>Eval Output:</h2>
        <pre class="output-box"><%= evalOutput %></pre>
      </div>
    <% } %>

    <% if (evalError) { %>
      <div class="form-card">
        <div class="alert alert-error">Eval Error: <%= evalError %></div>
      </div>
    <% } %>
  </div>
  <%- include('partials/footer') %>
</body>
</html>
