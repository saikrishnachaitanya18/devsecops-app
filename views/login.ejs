<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — VulnApp</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container">
    <div class="page-header">
      <h1>🔐 Login</h1>
      <p>Vulnerabilities: SQL Injection, Plaintext Passwords, No Rate Limiting, No CSRF</p>
    </div>

    <div class="form-card">
      <h2>Sign In</h2>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <!-- VULN: No CSRF token -->
      <form method="POST" action="/auth/login">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" placeholder="admin" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <!-- VULN: autocomplete not disabled -->
          <input type="password" id="password" name="password" placeholder="admin123" required>
        </div>
        <button type="submit" class="btn btn-primary">Login</button>
      </form>

      <div class="hint-box">
        <h4>💡 Test Credentials</h4>
        <p><strong>admin</strong> / <strong>admin123</strong></p>
        <p><strong>alice</strong> / <strong>alice123</strong></p>
        <h4>💉 SQL Injection Payloads</h4>
        <code>' OR '1'='1' --</code><br>
        <code>' UNION SELECT 1,2,3,4,5,6,7 --</code>
      </div>

      <p class="form-footer">Don't have an account? <a href="/auth/register">Register</a></p>
    </div>
  </div>
  <%- include('partials/footer') %>
</body>
</html>
