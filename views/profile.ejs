<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile — VulnApp</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container">
    <div class="page-header">
      <h1>👤 User Profile</h1>
      <p>Vulnerabilities: IDOR, Sensitive Data Exposure (SSN, Credit Card, Password)</p>
    </div>

    <div class="form-card">
      <h2>Profile Details</h2>
      <table class="data-table">
        <tr><th>ID</th><td><%= profile.id %></td></tr>
        <tr><th>Username</th><td><%= profile.username %></td></tr>
        <tr><th>Email</th><td><%= profile.email %></td></tr>
        <tr><th>Role</th><td><%= profile.role %></td></tr>
        <!-- VULN: Exposing sensitive data -->
        <tr><th>Password (plaintext!)</th><td><%= profile.password %></td></tr>
        <tr><th>SSN</th><td><%= profile.ssn %></td></tr>
        <tr><th>Credit Card</th><td><%= profile.credit_card %></td></tr>
      </table>

      <div class="hint-box">
        <h4>💡 IDOR Test</h4>
        <p>Try changing the ID in the URL to view other users' profiles:</p>
        <code>/auth/profile/1</code> — <code>/auth/profile/2</code> — <code>/auth/profile/3</code>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
</body>
</html>
