<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register — VulnApp</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container">
    <div class="page-header">
      <h1>📝 Register</h1>
      <p>Vulnerabilities: Mass Assignment, No Password Policy, No Input Validation, SQLi</p>
    </div>

    <div class="form-card">
      <h2>Create Account</h2>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <form method="POST" action="/auth/register">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" required>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="text" id="email" name="email" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required>
        </div>
        <!-- VULN: Mass assignment — hidden role field that can be manipulated -->
        <div class="form-group">
          <label for="role">Role (try changing to "admin")</label>
          <input type="text" id="role" name="role" value="user">
        </div>
        <button type="submit" class="btn btn-primary">Register</button>
      </form>
    </div>
  </div>
  <%- include('partials/footer') %>
</body>
</html>
